node_modules/
*.log

# The built SPA (frontend/dist) IS shipped — the plugin has no build step at install
# time, so the service must find a real bundle to serve. It is tracked on purpose.
# Ignore only transient build caches.
.vite/
frontend/.vite/
.DS_Store

# Local AI-tooling chat logs — never part of the shipped plugin
.aider*

# Local Claude Code state (scheduled-task locks, etc.) — never part of the shipped plugin
.claude/

# Secrets — guard against accidental commits
.env
.env.*

# npm pack output (CI/local smoke)
*.tgz

# wicked-interactive serve lockfile (runtime, per docs-root) — ADR-0022
.wi-serve.json
.wi-serve.log

# Playwright MCP scratch output
.playwright-mcp/
