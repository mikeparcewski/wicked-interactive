      Array.prototype.slice.call(bar.querySelectorAll(".ed-instr")).forEach(function (chip) {
        chip.addEventListener("click", function () { markUserActed(); if (selected) applyChange(selected, chip.getAttribute("data-instr")); });
      });
      bar.querySelector(".ed-say__form").addEventListener("submit", function (e) {
        e.preventDefault();
        markUserActed();
        if (!selected) return;
        var typed = bar.querySelector(".ed-say__input").value;
        applyChange(selected, classify(typed));
      });
      return bar;
    }

    promptForm.addEventListener("submit", function (e) { e.preventDefault(); markUserActed(); loadFormat(fmt, true); });
    fmtBtns.forEach(function (b) { b.addEventListener("click", function () { markUserActed(); loadFormat(b.getAttribute("data-fmt"), false); }); });

    styleForm.addEventListener("submit", function (e) {
      e.preventDefault(); markUserActed();
      var url = cleanUrl(styleUrl.value);
      var keys = ["stripe", "linear", "sunset"];
      importStyle(keys[styleTick++ % keys.length], url);
      styleUrl.value = "";
    });
    brandBtns.forEach(function (b) {
      b.addEventListener("click", function () {
        markUserActed();
        var k = b.getAttribute("data-theme");
        importStyle(k, THEMES[k].label);
      });
    });

    judgeBtns.forEach(function (b) {
      b.addEventListener("click", function () { markUserActed(); runReview(b.getAttribute("data-rev"), b); });
    });

    // Room 4 → drive the editor: load that format and scroll it into view.
    loadBtns.forEach(function (b) {
      b.addEventListener("click", function () {
        markUserActed();
        loadFormat(b.getAttribute("data-load"), false);
        if (editorEl && editorEl.scrollIntoView) editorEl.scrollIntoView({ behavior: reduced ? "auto" : "smooth", block: "center" });
      });
    });
    // Room 4 "Demo videos" card → jump to the demo-video section instead.
    gotoBtns.forEach(function (b) {
      b.addEventListener("click", function () {
        var target = document.getElementById(b.getAttribute("data-goto"));
        if (target && target.scrollIntoView) target.scrollIntoView({ behavior: reduced ? "auto" : "smooth", block: "start" });
      });
    });

    loadFormat("brief", false);

    if ("IntersectionObserver" in window && editorEl) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { io.disconnect(); setTimeout(startAutoDemo, reduced ? 0 : 900); }
        });
      }, { threshold: 0.08, rootMargin: "0px 0px -12% 0px" });
      io.observe(editorEl);
    }
    setTimeout(startAutoDemo, reduced ? 400 : 3200);
  })();
  </script>

  <!-- ════ THE DEMO-VIDEO ENGINE — aim→explore→record→storyboard ═════════ -->
  <script is:inline>
  (function () {
    "use strict";
    var states = ["vS1", "vS2", "vS3", "vS4"].map(function (id) { return document.getElementById(id); });
    var chs = ["vC1", "vC2", "vC3", "vC4"].map(function (id) { return document.getElementById(id); });
    var ledger = Array.prototype.slice.call(document.querySelectorAll(".vid-step"));
    var sbChs = Array.prototype.slice.call(document.querySelectorAll(".vid-sb-ch"));
    var fill = document.getElementById("vFill");
    var dot = document.getElementById("vDot");
    var recEl = document.getElementById("vRecTime");
    var dl = document.getElementById("vDl");
    var urlEl = document.getElementById("vUrl");
    var player = document.getElementById("vidPlayer");
    if (!states[0]) return;

    var URL_LABELS = [
      "localhost:4400 · new demo",
      "localhost:4400 · exploring…",
      "localhost:3000 · projects / new",
      "storyboard.html · 4 chapters"
    ];
    var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    var cur = 0, auto = null, thumbTimer = null;

    function startThumbCycle() {
      var i = 0;
      thumbTimer = setInterval(function () {
        i = (i + 1) % sbChs.length;
        sbChs.forEach(function (c, idx) { c.classList.toggle("active", idx === i); });
      }, 1200);
    }
    function stopThumbCycle() {
      clearInterval(thumbTimer); thumbTimer = null;
      sbChs.forEach(function (c, idx) { c.classList.toggle("active", idx === 0); });
    }

    function setStation(s) {
      cur = s;
      states.forEach(function (el, i) { if (el) el.classList.toggle("is-on", i === s); });
      chs.forEach(function (el, i) { if (el) el.className = "vid-ch" + (i === s ? " now" : i < s ? " past" : ""); });
      ledger.forEach(function (el, i) { el.classList.toggle("is-active", i === s); });
      if (fill) fill.style.width = ((s + 1) / 4 * 100) + "%";
      if (dot) dot.classList.toggle("is-on", s === 2);
      if (recEl) recEl.textContent = s === 2 ? "REC" : "";
      if (urlEl) urlEl.textContent = URL_LABELS[s];
      if (dl) dl.classList.toggle("done", s === 3);
      if (s === 3 && !thumbTimer) startThumbCycle();
      else if (s !== 3 && thumbTimer) stopThumbCycle();
    }

    function advance() { setStation((cur + 1) % 4); }
    function stop() { if (auto) { clearInterval(auto); auto = null; } }
    function play() { if (reduced) return; stop(); auto = setInterval(advance, 3400); }
    function jump(s) { setStation(s); play(); } // manual jump restarts the timer

    ledger.forEach(function (el, i) { el.addEventListener("click", function () { jump(i); }); });
    chs.forEach(function (el, i) { if (el) el.addEventListener("click", function () { jump(i); }); });
    sbChs.forEach(function (el, i) {
      el.addEventListener("click", function () {
        setStation(3); play();
        stopThumbCycle();
        sbChs.forEach(function (c, idx) { c.classList.toggle("active", idx === i); });
      });
    });
    if (dl) dl.addEventListener("click", function () { jump(3); });

    setStation(0);
    if ("IntersectionObserver" in window && player) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) { if (en.isIntersecting) play(); else stop(); });
      }, { threshold: 0.25 });
      io.observe(player);
    } else { play(); }
  })();
  </script>
