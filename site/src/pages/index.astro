<!-- Conveyor: one IntersectionObserver on four sentinels drives [data-station]. -->
<script is:inline>
(function () {
  "use strict";
  var stage = document.getElementById("stage");
  var sentinels = Array.prototype.slice.call(document.querySelectorAll(".sentinel"));

  // honour reduced-motion / narrow: the CSS hides the pin; skip the observer.
  var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  var narrow = window.matchMedia("(max-width: 900px)").matches;

  if (!prefersReduced && !narrow && "IntersectionObserver" in window) {
    var visible = {};
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        visible[e.target.getAttribute("data-s")] = e.intersectionRatio;
      });
      // pick the sentinel with the greatest coverage of the midline band
      var best = "1", bestRatio = -1;
      Object.keys(visible).forEach(function (k) {
        if (visible[k] > bestRatio) { bestRatio = visible[k]; best = k; }
      });
      if (stage.getAttribute("data-station") !== best) {
        stage.setAttribute("data-station", best);
      }
    }, {
      // a thin band centred on the viewport so the active station flips
      // cleanly at each quartile of the 400vh scroll
      rootMargin: "-49% 0px -49% 0px",
      threshold: [0, 1]
    });
    sentinels.forEach(function (s) { io.observe(s); });
  } else {
    // fallback: ensure stage shows the shipped end-state if ever visible
    stage.setAttribute("data-station", "4");
  }
})();
</script>

<!-- Prompt Playground -->
<script is:inline>
(function(){
  var PRESETS = [
    {
      label: 'Launch brief',
      prompt: 'Make me a one-page Q3 launch brief for the team.',
      titleOld: 'Our Q3 launch, explained for the whole team',
      titleNew: 'Ship Q3 with confidence — the plan, in one read',
      change: '"Make the headline punchier — lead with <em>shipping with confidence</em>."',
      changePlain: '"Make the headline punchier — lead with shipping with confidence."',
      conveyorChange: '"Make the headline punchier — lead with <em>shipping with confidence</em>, not explaining."',
    },
    {
      label: 'Investor deck',
      prompt: 'Build me a five-slide seed deck for our demo day.',
      titleOld: 'Why we exist — the case for backing us now',
      titleNew: 'The market chose us — back us to scale it',
      change: '"The traction slide feels too modest — lead with the numbers that matter."',
      changePlain: '"The traction slide feels too modest — lead with the numbers that matter."',
      conveyorChange: '"The traction slide feels too modest — make it land harder."',
    },
    {
      label: 'Onboarding guide',
      prompt: 'Write a first-week guide for new product team hires.',
      titleOld: 'Your first week: everything you need to know',
      titleNew: 'Your first week: welcome to the team',
      change: '"The opening reads like HR copy — make it warmer, more personal."',
      changePlain: '"The opening reads like HR copy — make it warmer, more personal."',
      conveyorChange: '"The opening reads like HR copy — make it warmer."',
    },
    {
      label: 'Release notes',
      prompt: 'Release notes for v2.1 — faster exports and new dashboard.',
      titleOld: "What's new in v2.1",
      titleNew: 'Dashboard-first: what changed in v2.1',
      change: '"Lead with the dashboard — it\'s the bigger feature, put it first."',
      changePlain: '"Lead with the dashboard — it\'s the bigger feature, put it first."',
      conveyorChange: '"Lead with the dashboard — it\'s the bigger feature, first."',
    },
  ];

  var current = 0;
  var pgPrompt = document.getElementById('pgPrompt');
  var chips = Array.prototype.slice.call(document.querySelectorAll('.pg-chip'));

  function getAllDyn(attr) {
    return Array.prototype.slice.call(document.querySelectorAll('[data-dyn="' + attr + '"]'));
  }

  function fadeOut(els, cb) {
    els.forEach(function(el){ el.classList.add('dyn-out'); });
    setTimeout(cb, 150);
  }

  function fadeIn(els) {
    els.forEach(function(el){ el.classList.remove('dyn-out'); });
  }

  function typewriter(el, text, onDone) {
    el.classList.add('fading');
    setTimeout(function(){
      el.textContent = '';
      el.classList.remove('fading');
      var i = 0;
      var speed = Math.max(18, Math.min(38, Math.floor(900 / text.length)));
      function tick() {
        if (i < text.length) {
          el.textContent += text[i++];
          setTimeout(tick, speed);
        } else if (onDone) {
          onDone();
        }
      }
      tick();
    }, 120);
  }

  function applyPreset(idx) {
    var p = PRESETS[idx];

    // 1. Typewriter the prompt box
    typewriter(pgPrompt, p.prompt);

    // 2. Fade out all data-dyn elements
    var oldEls = getAllDyn('title-old').concat(getAllDyn('title-new'));
    var promptEls = getAllDyn('prompt');
    var changeEls = getAllDyn('change');
    var allUpdating = oldEls.concat(promptEls).concat(changeEls);

    fadeOut(allUpdating, function(){
      // 3. Update text/html
      getAllDyn('title-old').forEach(function(el){ el.textContent = p.titleOld; });
      getAllDyn('title-new').forEach(function(el){ el.textContent = p.titleNew; });
      getAllDyn('prompt').forEach(function(el){ el.textContent = '"' + p.prompt + '"'; });
      // change: some have innerHTML (em tags), use appropriate method per context
      getAllDyn('change').forEach(function(el){
        var isConveyor = el.classList.contains('pc-body');
        el.innerHTML = isConveyor ? p.conveyorChange : p.change;
      });

      // 4. Fade back in
      setTimeout(function(){ fadeIn(allUpdating); }, 20);
    });

    // 5. Update chip active state
    chips.forEach(function(c, i){
      c.classList.toggle('is-active', i === idx);
    });

    current = idx;
  }

  // Wire chip clicks
  chips.forEach(function(chip){
    chip.addEventListener('click', function(){
      var idx = parseInt(chip.getAttribute('data-preset'), 10);
      if (idx !== current) applyPreset(idx);
    });
  });

  // Keyboard nav on chips
  document.getElementById('pgChips').addEventListener('keydown', function(e){
    if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
      var next = e.key === 'ArrowRight' ? (current + 1) % PRESETS.length : (current - 1 + PRESETS.length) % PRESETS.length;
      applyPreset(next);
      chips[next].focus();
      e.preventDefault();
    }
  });
})();
</script>

<!-- Video chapter seek -->
<script is:inline>
(function(){
  var DUR = 12000;
  var chs = document.querySelectorAll('.vid-sb-ch');
  chs.forEach(function(ch, i){
    ch.addEventListener('click', function(){
      var fill = document.getElementById('vFill');
      if (!fill) return;
      // Roughly map chapter i to its start time (4 equal quarters)
      var pct = i / 4;
      var elapsed = pct * DUR;
      // Dispatch a synthetic scrub via the bar's own click rect mapping is complex,
      // so instead we set elapsed directly and call render via the play button flow.
      // We do this by simulating a click on the bar at the right position.
      var bar = document.getElementById('vBar');
      if (!bar) return;
      var rect = bar.getBoundingClientRect();
      var x = rect.left + rect.width * pct + 1;
      bar.dispatchEvent(new MouseEvent('click', { clientX: x, bubbles: true }));
      // Activate the right chapter visually immediately
      chs.forEach(function(c, j){ c.classList.toggle('active', j === i); });
    });
  });
})();
</script>
