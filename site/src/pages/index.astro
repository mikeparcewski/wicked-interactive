---
/**
 * index.astro — the wicked-interactive landing page (wi.wickedagile.com).
 * Converted from the original single-file site/index.html to consume the shared
 * wicked-web chrome (Base + Topbar + Footer). Content, the prompt-playground,
 * the scroll-pinned "Conveyor", the demo-video scroller, and the mobile authored
 * stack are all preserved. The page's own topbar/footer markup + CSS and its
 * .dark-class theme system were removed: the shared chrome owns the chrome and
 * drives theming via [data-theme] (no-flash init in Base, toggle in Topbar).
 */
import Base from 'wicked-web/layouts/Base.astro';
import Topbar from 'wicked-web/components/Topbar.astro';
import Footer from 'wicked-web/components/Footer.astro';
import SameGarden from 'wicked-web/components/SameGarden.astro';
import '../styles/interactive.css';

const title = 'wicked-interactive \u2014 if you can say it, you can make it';
const description = 'wicked-interactive turns plain language into living documents: describe a deck, doc, landing page, or demo in your own words, watch it build in the browser, then point at any block and say what to change \u2014 it reworks just that block and keeps everything else. Export self-contained HTML, PDF, native PowerPoint, or video. Local-first; runs on the agent already in your session \u2014 no extra setup.';
const repo = 'https://github.com/mikeparcewski/wicked-interactive';
---

<Base title={title} description={description}>
  <Topbar pkg="wicked-interactive" repo={repo} />


<!-- ── Hero ────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="grid-floor"></div>
  <div class="wrap">
    <div class="kicker">Interactive HTML &amp; presentation builder · in-browser feedback loop</div>
    <h1>Describe it. Watch it build.<br>Point, say the change — <span class="y">ship it tonight.</span></h1>
    <p class="lede">No blank page. No screen recorder. Describe a document — a live themed draft renders instantly. Highlight any block and say the change, <b>it reworks just that block</b>. Or point it at any running app and get back a narrated interactive storyboard. One agent, both loops.</p>

    <div class="playground" role="group" aria-label="Try a different document type">
      <div class="pg-label">Try a different document type</div>
      <div class="pg-chips" id="pgChips">
        <button class="pg-chip is-active" data-preset="0" type="button">Launch brief</button>
        <button class="pg-chip" data-preset="1" type="button">Investor deck</button>
        <button class="pg-chip" data-preset="2" type="button">Onboarding guide</button>
        <button class="pg-chip" data-preset="3" type="button">Release notes</button>
      </div>
      <div class="pg-input" aria-live="polite">
        <span class="pg-user">You</span>
        <span class="pg-prompt" id="pgPrompt">Make me a one-page Q3 launch brief for the team.</span>
        <span class="pg-caret" aria-hidden="true"></span>
      </div>
      <p class="pg-hint">↕ updates the demo below</p>
    </div>

    <div class="scrollcue"><span class="bar"></span> Scroll — the artifact develops in place</div>
  </div>
</section>

<!-- ── THE CONVEYOR (scroll-pinned) ────────────────────────────────────── -->
<div class="conveyor" id="conveyor">

  <!-- invisible sentinels drive the station state -->
  <div class="sentinels" aria-hidden="true">
    <div class="sentinel" data-s="1"></div>
    <div class="sentinel" data-s="2"></div>
    <div class="sentinel" data-s="3"></div>
    <div class="sentinel" data-s="4"></div>
  </div>

  <!-- ONE sticky stage; ONE shared artifact element -->
  <div class="stage" id="stage" data-station="1"
       style="--y1: 23px; --y2: 30%; --y3: 55%; --y4: 80%;">
    <div class="stage-inner">

      <!-- intro copy — spans both columns -->
      <div class="conv-intro-row">
        <div class="kicker">The loop, on a belt</div>
        <h2>One artifact. Four stations. It becomes the thing you asked for.</h2>
        <p>The headline you read as a prompt at the first station is the exact same element that gets re-set and stamped at the last. Nothing else on the page is touched — that is the whole promise, shown rather than said.</p>
      </div>

      <!-- left rail station ledger -->
      <aside class="ledger">
        <div class="belt-label">Station ledger</div>
        <div class="track">
          <span class="tick" aria-hidden="true"></span>
          <div class="station" data-s="1">
            <div class="num">01</div>
            <div class="label">Describe</div>
            <div class="hint">Plain language, or point at your files / a URL.</div>
          </div>
          <div class="station" data-s="2">
            <div class="num">02</div>
            <div class="label">Watch&nbsp;it&nbsp;build</div>
            <div class="hint">A themed first draft renders live, instantly.</div>
          </div>
          <div class="station" data-s="3">
            <div class="num">03</div>
            <div class="label">Point&nbsp;&amp;&nbsp;say</div>
            <div class="hint">Highlight a block, say the change in English.</div>
          </div>
          <div class="station" data-s="4">
            <div class="num">04</div>
            <div class="label">Ship</div>
            <div class="hint">Regenerates in place, hot-reloads, exports.</div>
          </div>
        </div>
      </aside>

      <!-- doc head breadcrumb -->
      <div class="dochead">
        <span class="where">
          <span class="seg" data-s="1">DESCRIBE</span><span class="arrow">→</span><span class="seg" data-s="2">BUILD</span><span class="arrow">→</span><span class="seg" data-s="3">POINT</span><span class="arrow">→</span><span class="seg" data-s="4">SHIP</span>
        </span>
      </div>

      <!-- the ONE artifact -->
      <div class="artifact-cell">
        <article class="artifact">
          <div class="chrome">
            <div class="lights"><i></i><i></i><i></i></div>
            <div class="url">localhost:4400 · q3-launch-brief.html</div>
            <div class="live"><span class="pulse"></span>Live</div>
          </div>
          <div class="doc">
            <div class="doc-kicker">Q3 Launch · One-page brief</div>

            <!-- THE headline = the object that travels the whole loop -->
            <h2 class="headline">
              <span class="swap-old" data-dyn="title-old">Our Q3 launch, explained for the whole team</span>
              <span class="swap-new" data-dyn="title-new">Ship Q3 with confidence — the plan, in one read</span>
            </h2>

            <p class="doc-sub">A single page leadership and the floor can both act on — no decks, no doc sprawl.</p>

            <div class="rows">
              <div class="row"><span class="tickmark"></span><span class="rtext"><b>What ships:</b> the new onboarding flow and the pricing refresh, together.</span></div>
              <div class="row"><span class="tickmark"></span><span class="rtext"><b>Why now:</b> renewals open in August — we want the story landed first.</span></div>
              <div class="row"><span class="tickmark"></span><span class="rtext"><b>Who owns what:</b> one accountable name per workstream, listed below.</span></div>
            </div>

            <!-- station 4 exports (in-flow, below list) -->
            <div class="exports">
              <span class="ex-lbl">Export</span>
              <span class="chip"><span class="lock"></span>HTML</span>
              <span class="chip"><span class="lock"></span>PDF</span>
              <span class="chip"><span class="lock"></span>PPTX</span>
              <span class="chip"><span class="lock"></span>Video</span>
            </div>

            <!-- station 1 prompt -->
            <div class="prompt-strip">
              <span class="lbl">You</span>
              <span><span data-dyn="prompt">"Make me a one-page Q3 launch brief for the team"</span><span class="caret"></span></span>
            </div>

            <!-- station 3 docked instruction card -->
            <div class="point-card">
              <div class="pc-lbl">You pointed here</div>
              <div class="pc-body" data-dyn="change">"Make the headline punchier — lead with <em>shipping with confidence</em>, not explaining."</div>
              <div class="pc-meta"><span class="gear"></span> Reworking this block only…</div>
            </div>
            <div class="redline" aria-hidden="true"></div>

            <!-- station 4 stamp -->
            <div class="stamp">Locked ✓</div>
          </div>
          <div class="art-controls">
            <div class="art-timeline">
              <div class="art-bar"><div class="art-fill"></div></div>
              <div class="art-chs">
                <span class="art-ch" data-s="1">Describe</span>
                <span class="art-ch" data-s="2">Build</span>
                <span class="art-ch" data-s="3">Point</span>
                <span class="art-ch" data-s="4">Ship</span>
              </div>
            </div>
          </div>
        </article>
      </div>

    </div>
  </div>
</div>

<!-- ── Reduced-motion / mobile authored stack ──────────────────────────── -->
<div class="stack-only">
  <section class="wrap">
    <div class="stack">

      <div class="stack-step">
        <div class="stack-rail"><span class="dot"></span><div class="num">01</div><div class="lab">Describe</div></div>
        <div class="stack-card">
          <div class="sk">You — plain language</div>
          <div class="sh" data-dyn="title-old">Our Q3 launch, explained for the whole team</div>
          <p class="sp"><span class="mut" data-dyn="prompt">”Make me a one-page Q3 launch brief for the team.”</span> No blank page, no terminal — say it, or point at your files and a URL.</p>
        </div>
      </div>

      <div class="stack-step">
        <div class="stack-rail"><span class="dot"></span><div class="num">02</div><div class="lab">Watch it build</div></div>
        <div class="stack-card">
          <div class="sk">Rendered live · localhost:4400</div>
          <div class="sh" data-dyn="title-old">Our Q3 launch, explained for the whole team</div>
          <p class="sp">A real, themed first draft appears in the browser instantly — what ships, why now, who owns what, and the one risk, all on one page.</p>
        </div>
      </div>

      <div class="stack-step">
        <div class="stack-rail"><span class="dot"></span><div class="num">03</div><div class="lab">Point &amp; say</div></div>
        <div class="stack-card">
          <div class="sk">You pointed at the headline</div>
          <div class="sh" data-dyn="title-old">Our Q3 launch, explained for the whole team</div>
          <p class="sp"><span data-dyn="change">”Make the headline punchier — lead with <em>shipping with confidence</em>.”</span> The supervising agent reworks <em>just that block</em>, preserving everything else.</p>
        </div>
      </div>

      <div class="stack-step">
        <div class="stack-rail"><span class="dot"></span><div class="num">04</div><div class="lab">Ship</div></div>
        <div class="stack-card">
          <span class="badge">Re-set ✓</span>
          <div class="sk">Regenerated in place · hot-reloaded</div>
          <div class="sh" data-dyn="title-new">Ship Q3 with confidence — the plan, in one read</div>
          <p class="sp">Only the headline changed. Export a self-contained file and you're done by tonight.</p>
          <div class="schips"><span class="c">HTML</span><span class="c">PDF</span><span class="c">PPTX</span><span class="c">Video</span></div>
        </div>
      </div>

    </div>
  </section>
</div>

