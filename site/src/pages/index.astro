---
/**
 * index.astro — wicked-interactive landing page (wi.wickedagile.com).
 *
 * The hero IS the demo: the "Talkback Canvas" — a real, hands-on point-and-say
 * editor the visitor drives. describe -> build (block-by-block shimmer) ->
 * click a block, say the change (highlighter + "only this block touched" halo)
 * -> rewind via version pips. A canned engine, but it genuinely reacts to
 * clicks and typed input. The old scroll-pinned Conveyor, the demo-video
 * scroll-jack, and the preset-cycling playground are gone.
 *
 * Shared wicked-web chrome (Base + Topbar + Footer) owns the chrome and drives
 * theming via [data-theme]; this page styles the canvas + the how-it-works beat.
 */
import Base from 'wicked-web/layouts/Base.astro';
import Topbar from 'wicked-web/components/Topbar.astro';
import Footer from 'wicked-web/components/Footer.astro';
import '../styles/interactive.css';

const title = 'wicked-interactive — Point at the page. Say the change. Ship it tonight.';
const description = 'wicked-interactive turns plain language into living documents: describe a deck, doc, landing page, or demo, watch it build in the browser, then click any block and say the change — only that block reworks, everything else holds. Export self-contained HTML, PDF, PowerPoint, or video. Local-first; runs on the agent already in your session — no extra setup.';
const repo = 'https://github.com/mikeparcewski/wicked-interactive';
---

<Base title={title} description={description}>
  <Topbar pkg="wicked-interactive" repo={repo} />

  <!-- ── Hero = the demo ──────────────────────────────────────────────── -->
  <section class="hero">
    <div class="wrap">
      <div class="kicker">Interactive document builder · point-and-say editing</div>
      <h1>Point at the page. Say the change. <span class="y">Ship it tonight.</span></h1>
      <p class="lede">Describe a doc and watch it build, live. Then click any block and say what to change &mdash; <b>only that block reworks</b>, everything else holds perfectly still. Try it right here.</p>

      <div class="tc" id="tc">
        <!-- Point at anything: reloads the SAME canvas with a new format -->
        <div class="tc-switch" role="group" aria-label="Point at any format">
          <span class="tc-switch__lbl">Point at anything</span>
          <button class="tc-fmt is-active" type="button" data-fmt="brief">Launch brief</button>
          <button class="tc-fmt" type="button" data-fmt="deck">Investor deck</button>
          <button class="tc-fmt" type="button" data-fmt="page">Landing page</button>
          <button class="tc-fmt" type="button" data-fmt="video">Demo video</button>
        </div>

        <div class="tc-stage">
          <!-- the browser-framed paper document -->
          <div class="tc-frame" id="tcFrame">
            <div class="tc-chrome">
              <span class="tc-lights" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="tc-url" id="tcUrl">localhost:4400 · q3-launch-brief.html</span>
              <span class="tc-live"><span class="tc-pulse" aria-hidden="true"></span>Live</span>
            </div>

            <form class="tc-prompt" id="tcPromptForm">
              <span class="tc-you">You</span>
              <input class="tc-input" id="tcInput" type="text" autocomplete="off"
                     aria-label="Describe the document to build"
                     value="One-page Q3 launch brief for the whole team." />
              <button class="tc-build" type="submit">Build &crarr;</button>
            </form>

            <div class="tc-doc" id="tcDoc" aria-live="polite"></div>

            <div class="tc-export" id="tcExport">
              <span class="tc-export__lbl">Ship it</span>
              <button class="tc-ex" type="button" data-ex="HTML">HTML</button>
              <button class="tc-ex" type="button" data-ex="PDF">PDF</button>
              <button class="tc-ex" type="button" data-ex="PPTX">PPTX</button>
              <button class="tc-ex" type="button" data-ex="Video">Video</button>
              <span class="tc-export__status" id="tcExStatus"></span>
            </div>
          </div>

          <!-- version rail: real edit history, click to rewind -->
          <aside class="tc-versions" aria-label="Version history">
            <div class="tc-versions__head">Versions <span>click to rewind</span></div>
            <div class="tc-pips" id="tcPips"></div>
          </aside>
        </div>

        <p class="tc-hint" id="tcHint">Click any line in the page above, then say the change.</p>
      </div>
    </div>
  </section>

  <!-- ── How it works: three moves + the format/export beat ───────────── -->
  <section class="how">
    <div class="wrap">
      <div class="how-head">
        <div class="kicker">How it works</div>
        <h2>Three moves, <span class="y">one canvas.</span></h2>
        <p class="how-lede">No round-trips, no design tickets, no rebuilding the whole thing to fix one line. Describe it, point at what's wrong, ship a self-contained file.</p>
      </div>

      <ol class="how-steps">
        <li class="step">
          <span class="step__n">1</span>
          <h3>Describe it</h3>
          <p>Say what you want in plain language. It builds in the browser, block by block &mdash; you watch the page appear as you talk.</p>
        </li>
        <li class="step">
          <span class="step__n">2</span>
          <h3>Point and say</h3>
          <p>Click any block and say the change. <em>Only that block</em> reworks &mdash; every other block holds perfectly still.</p>
        </li>
        <li class="step">
          <span class="step__n">3</span>
          <h3>Ship it</h3>
          <p>Rewind any edit through the version rail, then export one self-contained file. Nothing to host, nothing to wire up.</p>
        </li>
      </ol>

      <div class="beat">
        <div class="beat__col beat__col--fmt">
          <span class="beat__lbl">Point at any format</span>
          <ul class="beat__chips">
            <li>Launch brief</li>
            <li>Investor deck</li>
            <li>Landing page</li>
            <li>Demo video</li>
          </ul>
        </div>
        <div class="beat__col beat__col--out">
          <span class="beat__lbl">Export, self-contained</span>
          <ul class="beat__chips">
            <li>HTML</li>
            <li>PDF</li>
            <li>PowerPoint</li>
            <li>Video</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Closer → From the same garden → Footer ───────────────────────── -->
  <div class="finale">
    <section class="closer">
      <div class="wrap closer-grid">
        <div class="closer-intro">
          <div class="kicker">That's the whole product</div>
          <h2>One block changed. Everything else held.</h2>
          <p>No round-trip, no design ticket, no rewriting the whole thing to fix one line. You point at what's wrong, say it in plain English, and <em>only that block</em> reworks &mdash; then export a self-contained file and you're done tonight.</p>
        </div>

        <div class="install-group" role="group" aria-label="Install wicked-interactive">
          <div class="install install--primary">
            <div class="install__bar">
              <span class="install__label">Install the family <span class="install__tag">recommended</span></span>
              <button class="install__copy" type="button" aria-label="Copy installer command"
                onclick="navigator.clipboard&&navigator.clipboard.writeText('npx wicked-installer').then(()=>{this.textContent='Copied';setTimeout(()=>{this.textContent='Copy';},1400);})">Copy</button>
            </div>
            <pre class="install__code"><code><span class="p">npx</span> wicked-installer</code></pre>
            <p class="install__note">Interactive picker &mdash; choose your products, wire them across CLIs, and get the <code>wicked</code> command. Installs wicked-interactive and anything else you want in one pass.</p>
          </div>
          <div class="install install--secondary">
            <div class="install__bar">
              <span class="install__label">or install just this directly</span>
              <button class="install__copy" type="button" aria-label="Copy direct install commands"
                onclick="navigator.clipboard&&navigator.clipboard.writeText('/plugin marketplace add mikeparcewski/wicked-interactive\n/plugin install wicked-interactive').then(()=>{this.textContent='Copied';setTimeout(()=>{this.textContent='Copy';},1400);})">Copy</button>
            </div>
            <pre class="install__code"><code><span class="p">/plugin</span> marketplace add mikeparcewski/wicked-interactive
<span class="p">/plugin</span> install wicked-interactive</code></pre>
          </div>
        </div>

        <a class="gh-pill" href="https://github.com/mikeparcewski/wicked-interactive#readme" target="_blank" rel="noopener" aria-label="View on GitHub">
          <svg viewBox="0 0 16 16" width="44" height="44" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.02-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          <span>View on Github</span>
        </a>
      </div>
    </section>


    <Footer repo={repo} />
  </div>

  <!-- ── Talkback Canvas engine (real, driven, canned data) ───────────── -->
  <script is:inline>
  (function () {
    "use strict";

    // instruction -> label
    var INSTR = { punchier: "Punchier", warmer: "Warmer", stat: "Add a stat", tighten: "Tighten" };
    var ORDER = ["punchier", "warmer", "stat", "tighten"];

    // each format: prompt + url + ordered blocks. Every block carries a base
    // text and four rewrites — so a click OR a typed instruction genuinely
    // produces different, sensible copy for THAT block only.
    var DOCS = {
      brief: {
        prompt: "One-page Q3 launch brief for the whole team.",
        url: "localhost:4400 · q3-launch-brief.html",
        kicker: "Q3 Launch · One-page brief",
        blocks: [
          { id: "h", kind: "h", text: "Our Q3 launch, explained for the whole team", v: {
            punchier: "Ship Q3 with confidence — the whole plan, one read",
            warmer: "Here's how we land Q3 together",
            stat: "Q3 launch: 3 workstreams, 1 page, 0 surprises",
            tighten: "The Q3 launch plan" } },
          { id: "s", kind: "sub", text: "A single page leadership and the floor can both act on.", v: {
            punchier: "One page. Everyone aligned. No deck sprawl.",
            warmer: "So everyone knows the plan — and feels part of it.",
            stat: "One page replacing four decks and a 30-slide readout.",
            tighten: "One page everyone can act on." } },
          { id: "r1", kind: "row", text: "What ships: the new onboarding flow and the pricing refresh, together.", v: {
            punchier: "What ships: onboarding + pricing — shipped as one story.",
            warmer: "What we're shipping: a smoother welcome and fairer pricing.",
            stat: "What ships: two launches, one window, 40% faster onboarding.",
            tighten: "Ships: onboarding + pricing refresh." } },
          { id: "r2", kind: "row", text: "Why now: renewals open in August — we want the story landed first.", v: {
            punchier: "Why now: August renewals. The story lands first, or not at all.",
            warmer: "Why now: renewals are coming, and we want folks ready.",
            stat: "Why now: $2.4M in renewals open August 1.",
            tighten: "Why now: renewals open August." } }
        ]
      },
      deck: {
        prompt: "Five-slide seed deck for demo day.",
        url: "localhost:4400 · seed-deck.html · slide 1/5",
        kicker: "Seed round · Slide 1",
        blocks: [
          { id: "h", kind: "h", text: "Why we exist — the case for backing us now", v: {
            punchier: "The market already chose us. Back us to scale it.",
            warmer: "We're building the tool teams keep asking us for",
            stat: "4,000 teams. 3 months. Backed by usage, not hope.",
            tighten: "The case to back us now" } },
          { id: "s", kind: "sub", text: "The problem, the wedge, and why this team wins it.", v: {
            punchier: "A broken workflow, a sharp wedge, a team that ships.",
            warmer: "Here's the problem we love — and why it's ours to win.",
            stat: "A $12B market, 92% of it still done by hand.",
            tighten: "Problem, wedge, team." } },
          { id: "r1", kind: "row", text: "Traction: 4,000 teams onboarded in the first quarter.", v: {
            punchier: "Traction: 0 to 4,000 teams in one quarter — no paid spend.",
            warmer: "Traction: 4,000 teams already trust us day to day.",
            stat: "Traction: 4,000 teams · 38% WoW growth · $0 CAC.",
            tighten: "Traction: 4,000 teams in Q1." } },
          { id: "r2", kind: "row", text: "Ask: $3M to turn demand into a category.", v: {
            punchier: "Ask: $3M to own the category before anyone else moves.",
            warmer: "Ask: $3M to bring this to every team that needs it.",
            stat: "Ask: $3M · 24-month runway · 5x pipeline coverage.",
            tighten: "Ask: $3M seed." } }
        ]
      },
      page: {
        prompt: "Landing page hero for our new pricing tool.",
        url: "localhost:4400 · pricing-tool.html",
        kicker: "Landing page · Hero",
        blocks: [
          { id: "h", kind: "h", text: "Pricing that finally makes sense for your team", v: {
            punchier: "Stop guessing at pricing. Ship the right number today.",
            warmer: "Pricing your whole team can actually understand",
            stat: "Set prices 10x faster — no spreadsheet gymnastics",
            tighten: "Pricing that makes sense" } },
          { id: "s", kind: "sub", text: "Model, compare, and publish pricing without a spreadsheet.", v: {
            punchier: "Model it, compare it, ship it — before the meeting ends.",
            warmer: "We'll help you find a price that feels fair to everyone.",
            stat: "Used by 1,200 teams to price in minutes, not weeks.",
            tighten: "Model, compare, publish — no spreadsheet." } },
          { id: "r1", kind: "row", text: "See every plan side by side in one clean view.", v: {
            punchier: "Every plan, side by side, decided in one glance.",
            warmer: "See all your options together, so the choice feels easy.",
            stat: "Compare up to 8 plans across 20 metrics instantly.",
            tighten: "All plans, one view." } },
          { id: "r2", kind: "row", text: "Publish to your site with one click — no engineer needed.", v: {
            punchier: "One click to publish. No ticket, no engineer, no wait.",
            warmer: "Publish whenever you're ready — we handle the rest.",
            stat: "Publish in one click · live in under 30 seconds.",
            tighten: "Publish in one click." } }
        ]
      },
      video: {
        prompt: "Narrated demo of our onboarding flow.",
        url: "localhost:4400 · onboarding-demo.mp4 · 4 chapters",
        kicker: "Demo video · Storyboard",
        blocks: [
          { id: "h", kind: "h", text: "A guided tour of your first five minutes", v: {
            punchier: "Your first five minutes — and why they'll hook you",
            warmer: "Let's walk through your first five minutes together",
            stat: "First 5 minutes · 4 chapters · 1:34 runtime",
            tighten: "Your first five minutes" } },
          { id: "s", kind: "sub", text: "We record the flow, narrate each step, and hand back a storyboard.", v: {
            punchier: "Recorded, narrated, storyboarded — zero editing from you.",
            warmer: "We'll capture it and talk you through every step.",
            stat: "4 chapters auto-captured from 12 clicks.",
            tighten: "Recorded, narrated, storyboarded." } },
          { id: "r1", kind: "row", text: "Chapter 1: create your first project in three clicks.", v: {
            punchier: "Chapter 1: first project, three clicks, done.",
            warmer: "Chapter 1: we'll set up your first project together.",
            stat: "Chapter 1: first project in 3 clicks · 18 seconds.",
            tighten: "Ch. 1: first project, 3 clicks." } },
          { id: "r2", kind: "row", text: "Chapter 4: export your work and share the link.", v: {
            punchier: "Chapter 4: export, share, ship — the loop closes.",
            warmer: "Chapter 4: export your work and send it to whoever needs it.",
            stat: "Chapter 4: export in one click · 6 formats.",
            tighten: "Ch. 4: export and share." } }
        ]
      }
    };

    var KIND_NAME = { h: "Headline", sub: "Subhead", row: "Body line" };

    var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    var doc = document.getElementById("tcDoc");
    var urlEl = document.getElementById("tcUrl");
    var input = document.getElementById("tcInput");
    var promptForm = document.getElementById("tcPromptForm");
    var pipsEl = document.getElementById("tcPips");
    var frame = document.getElementById("tcFrame");
    var exStatus = document.getElementById("tcExStatus");
    var fmtBtns = Array.prototype.slice.call(document.querySelectorAll(".tc-fmt"));
    var exBtns = Array.prototype.slice.call(document.querySelectorAll(".tc-ex"));

    // live state
    var fmt = "brief";
    var live = {};          // id -> { key, text }
    var history = [];       // [{ vlabel, whatHTML, blocks:{id:{key,text}} }]
    var active = 0;
    var selected = null;    // block id currently selected
    var building = false;

    // the docked "say the change" bar (built once, reparented under a block)
    var sayBar = buildSayBar();

    function clone(o) { return JSON.parse(JSON.stringify(o)); }
    function defFor(id) { return DOCS[fmt].blocks.filter(function (b) { return b.id === id; })[0]; }

    // classify a free-typed instruction; null if we can't tell -> we rotate
    function classify(t) {
      t = (t || "").toLowerCase();
      if (/punch|bold|strong|sharp|snapp|confiden|impact|assertive|louder|energ/.test(t)) return "punchier";
      if (/warm|friend|human|kind|personal|approach|soft|gentl|welcom/.test(t)) return "warmer";
      if (/stat|number|metric|data|proof|%|percent|figure|quantif|hard evidence|numeric/.test(t)) return "stat";
      if (/tight|short|trim|cut|concise|brief|less|snip|condens|crisp/.test(t)) return "tighten";
      return null;
    }

    // choose a variant key that actually changes the text
    function pickKey(id, prefer) {
      var def = defFor(id), cur = live[id];
      if (prefer && def.v[prefer] && def.v[prefer] !== cur.text) return prefer;
      var start = ORDER.indexOf(cur.key); // -1 for "base"
      for (var n = 1; n <= ORDER.length; n++) {
        var k = ORDER[(Math.max(start, 0) + n) % ORDER.length];
        if (def.v[k] && def.v[k] !== cur.text) return k;
      }
      return prefer || ORDER[0];
    }

    // ---- render the document from `live` -----------------------------------
    function render(build) {
      closeSay();
      doc.innerHTML = "";
      var kick = document.createElement("div");
      kick.className = "tc-doc__kicker";
      kick.textContent = DOCS[fmt].kicker;
      doc.appendChild(kick);

      var rowGroup = null;
      DOCS[fmt].blocks.forEach(function (bd) {
        var st = live[bd.id];
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "tc-block tc-block--" + bd.kind;
        btn.setAttribute("data-id", bd.id);
        var shim = document.createElement("span");
        shim.className = "tc-block__shim";
        shim.setAttribute("aria-hidden", "true");
        var t = document.createElement("span");
        t.className = "tc-block__t";
        t.textContent = st.text;
        btn.appendChild(shim);
        btn.appendChild(t);
        btn.addEventListener("click", function () { selectBlock(bd.id, btn); });

        // group the body rows so they sit together with tick marks
        if (bd.kind === "row") {
          if (!rowGroup) { rowGroup = document.createElement("div"); rowGroup.className = "tc-rowgroup"; doc.appendChild(rowGroup); }
          rowGroup.appendChild(btn);
        } else {
          rowGroup = null;
          doc.appendChild(btn);
        }
        if (build) btn.classList.add("tc-block--building");
      });

      if (build) assemble();
    }

    // block-by-block shimmer reveal
    function assemble() {
      building = true;
      var blocks = Array.prototype.slice.call(doc.querySelectorAll(".tc-block--building"));
      var step = reduced ? 40 : 260;
      blocks.forEach(function (b, i) {
        setTimeout(function () {
          b.classList.remove("tc-block--building");
          if (i === blocks.length - 1) building = false;
        }, (i + 1) * step);
      });
      if (!blocks.length) building = false;
    }

    // ---- selection: highlighter sweep + dock the say bar -------------------
    function selectBlock(id, btn) {
      if (building) return;
      if (selected === id) { closeSay(); return; }
      Array.prototype.slice.call(doc.querySelectorAll(".tc-block")).forEach(function (b) {
        b.classList.remove("is-target");
      });
      // retrigger the sweep animation
      btn.classList.remove("is-target"); void btn.offsetWidth; btn.classList.add("is-target");
      selected = id;
      // reference the label through sayBar — it lives detached until inserted,
      // so getElementById would be null on the first-ever selection.
      sayBar.querySelector(".tc-say__what").textContent = KIND_NAME[defFor(id).kind];
      sayBar.querySelector(".tc-say__input").value = "";
      btn.insertAdjacentElement("afterend", sayBar);
      sayBar.classList.add("is-open");
    }

    function closeSay() {
      sayBar.classList.remove("is-open");
      if (sayBar.parentNode) sayBar.parentNode.removeChild(sayBar);
      Array.prototype.slice.call(doc.querySelectorAll(".is-target")).forEach(function (b) {
        b.classList.remove("is-target");
      });
      selected = null;
    }

    // ---- apply a change to ONE block --------------------------------------
    function applyChange(id, prefer) {
      var key = pickKey(id, prefer);
      var def = defFor(id);
      var newText = def.v[key];
      var btn = doc.querySelector('.tc-block[data-id="' + id + '"]');
      if (!btn) return;

      // if we rewound into the past, a new edit forks the timeline
      if (active < history.length - 1) history = history.slice(0, active + 1);

      closeSay();
      doc.classList.add("is-focusing");
      btn.classList.add("is-target", "tc-block--reworking");
      var t = btn.querySelector(".tc-block__t");

      var wait = reduced ? 60 : 560;
      setTimeout(function () {
        live[id] = { key: key, text: newText };
        t.textContent = newText;
        btn.classList.remove("tc-block--reworking", "is-target");
        void btn.offsetWidth;
        btn.classList.add("tc-block--changed");
        setTimeout(function () {
          btn.classList.remove("tc-block--changed");
          doc.classList.remove("is-focusing");
        }, reduced ? 400 : 1500);

        // log the version
        pushVersion(KIND_NAME[def.kind], INSTR[key]);
      }, wait);
    }

    // ---- version rail ------------------------------------------------------
    function pushVersion(what, instr) {
      history.push({
        vlabel: "v" + history.length,
        whatHTML: what + ' &rarr; <em>' + instr + '</em>',
        blocks: clone(live)
      });
      active = history.length - 1;
      renderPips();
    }

    function renderPips() {
      pipsEl.innerHTML = "";
      history.forEach(function (h, i) {
        var pip = document.createElement("button");
        pip.type = "button";
        pip.className = "tc-pip" + (i === active ? " is-active" : "");
        pip.innerHTML =
          '<span class="tc-pip__dot" aria-hidden="true"></span>' +
          '<span class="tc-pip__body"><span class="tc-pip__v">' + h.vlabel + '</span>' +
          '<span class="tc-pip__what">' + h.whatHTML + '</span></span>';
        pip.addEventListener("click", function () { rewind(i); });
        pipsEl.appendChild(pip);
      });
    }

    // rewind restores a snapshot; editing from here forks (handled in applyChange)
    function rewind(i) {
      if (building) return;
      active = i;
      live = clone(history[i].blocks);
      render(false);
      renderPips();
      // brief flash to show the doc reset to that version
      if (!reduced) {
        Array.prototype.slice.call(doc.querySelectorAll(".tc-block")).forEach(function (b, n) {
          b.classList.add("tc-block--changed");
          setTimeout(function () { b.classList.remove("tc-block--changed"); }, 700);
        });
      }
    }

    // ---- build/rebuild for a format ---------------------------------------
    function loadFormat(f, fromPrompt) {
      fmt = f;
      selected = null;
      live = {};
      DOCS[f].blocks.forEach(function (b) { live[b.id] = { key: "base", text: b.text }; });
      history = [{ vlabel: "v0", whatHTML: "First draft", blocks: clone(live) }];
      active = 0;
      urlEl.textContent = DOCS[f].url;
      if (!fromPrompt) input.value = DOCS[f].prompt;
      resetExport();
      render(true);
      renderPips();
      fmtBtns.forEach(function (b) { b.classList.toggle("is-active", b.getAttribute("data-fmt") === f); });
    }

    // ---- export: the click IS the pitch -----------------------------------
    function resetExport() {
      exBtns.forEach(function (b) { b.classList.remove("is-locked"); });
      frame.classList.remove("is-shipped");
      exStatus.textContent = "";
    }
    var exTimer = null;
    exBtns.forEach(function (b) {
      b.addEventListener("click", function () {
        var f = b.getAttribute("data-ex");
        clearTimeout(exTimer);
        exBtns.forEach(function (x) { x.classList.remove("is-locked"); });
        b.classList.add("is-locked");
        frame.classList.remove("is-shipped");
        exStatus.innerHTML = "Packaging " + f + "…";
        exTimer = setTimeout(function () {
          frame.classList.add("is-shipped");
          exStatus.innerHTML = "<b>" + f + "</b> · one self-contained file ✓";
        }, reduced ? 120 : 680);
      });
    });

    // ---- the "say the change" bar (built once) ----------------------------
    function buildSayBar() {
      var bar = document.createElement("div");
      bar.className = "tc-say";
      bar.innerHTML =
        '<div class="tc-say__head">' +
          '<span class="tc-say__tag">Editing</span>' +
          '<span class="tc-say__what" id="tcSayWhat">Headline</span>' +
          '<button class="tc-say__x" type="button">Done</button>' +
        '</div>' +
        '<div class="tc-say__chips">' +
          '<button class="tc-instr" type="button" data-instr="punchier">Punchier</button>' +
          '<button class="tc-instr" type="button" data-instr="warmer">Warmer</button>' +
          '<button class="tc-instr" type="button" data-instr="stat">Add a stat</button>' +
          '<button class="tc-instr" type="button" data-instr="tighten">Tighten</button>' +
        '</div>' +
        '<form class="tc-say__form">' +
          '<input class="tc-say__input" type="text" autocomplete="off" placeholder="…or say your own change" aria-label="Say your own change" />' +
          '<button class="tc-say__go" type="submit">Go →</button>' +
        '</form>';
      bar.querySelector(".tc-say__x").addEventListener("click", closeSay);
      Array.prototype.slice.call(bar.querySelectorAll(".tc-instr")).forEach(function (chip) {
        chip.addEventListener("click", function () {
          if (selected) applyChange(selected, chip.getAttribute("data-instr"));
        });
      });
      bar.querySelector(".tc-say__form").addEventListener("submit", function (e) {
        e.preventDefault();
        if (!selected) return;
        var typed = bar.querySelector(".tc-say__input").value;
        applyChange(selected, classify(typed)); // matched intent, or null -> rotate
      });
      return bar;
    }

    // ---- wire the header prompt + format switcher -------------------------
    promptForm.addEventListener("submit", function (e) { e.preventDefault(); loadFormat(fmt, true); });
    fmtBtns.forEach(function (b) {
      b.addEventListener("click", function () { loadFormat(b.getAttribute("data-fmt"), false); });
    });

    // boot
    loadFormat("brief", false);
  })();
  </script>
</Base>
