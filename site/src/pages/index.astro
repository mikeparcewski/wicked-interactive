      setTimeout(function () { if (userActed) cueReady(); }, reduced ? 300 : 1400);
    }

    function applyTheme(key, silent) {
      var th = THEMES[key] || THEMES._default;
      doc.style.setProperty("--paper", th.paper);
      doc.style.setProperty("--paper-ink", th.ink);
      doc.style.setProperty("--paper-muted", th.muted);
      doc.style.setProperty("--accent", th.accent);
      doc.style.setProperty("--halo", th.halo);
      brandBtns.forEach(function (b) { b.classList.toggle("is-active", b.getAttribute("data-theme") === key); });
      if (!silent && !reduced) { doc.classList.remove("is-retheming"); void doc.offsetWidth; doc.classList.add("is-retheming"); }
    }
    function importStyle(key, label) {
      if (!THEMES[key]) return;
      curTheme = key;
      applyTheme(key, false);
      commitVersion('Style &rarr; <em>learned from ' + label + '</em>');
      setCue("ready", "Restyled from <b>" + label + "</b> &mdash; and it sticks for every later edit.");
    }
    function cleanUrl(u) {
      return (u || "").replace(/^https?:\/\//i, "").replace(/^www\./i, "").replace(/\/+$/, "").slice(0, 40) || "your-brand.com";
    }

    function verdictRow(key) {
      var row = verdictsEl.querySelector('.ed-verdict[data-rev="' + key + '"]');
      if (!row) { row = document.createElement("div"); row.setAttribute("data-rev", key); verdictsEl.appendChild(row); }
      return row;
    }
    function runReview(key, btn) {
      var r = REV[key]; if (!r) return;
      btn.classList.add("is-running"); btn.classList.remove("is-passed");
