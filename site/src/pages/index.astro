---
/**
 * index.astro — wicked-interactive landing (wi.wickedagile.com).
 *
 * A HYBRID of the two builds, on the family DARK ground:
 *   1. Hero              — the clean statement hero from the LIVE (f26d5fd) build.
 *   2. Point at anything — the live editor + style import + the four judges (NEW
 *                          build), moved into its own section; the "Demo video"
 *                          chip is gone from its selector — it's a section now.
 *   3. Demo video        — the interactive aim→explore→record→storyboard player
 *                          revived from the original LIVE build, rebuilt as an
 *                          auto-advancing + clickable stepper (no scroll-jack) so
 *                          it lives in one snapped viewport.
 *   4. Make anything / Send anything                              (NEW build).
 *   5. Under the hood    — the real feature surface                (NEW build).
 *   6. Closer "That's the whole product"                          (NEW build).
 *
 * Both demo engines are canned (repeatable, honest — see the notes under them);
 * the real product runs on the Claude Code session already in the visitor's
 * terminal over wicked-bus. Shared wicked-web chrome (Base/Topbar/Footer) owns
 * the header, footer, and fonts; this page styles + drives the studio, dark.
 */
import Base from 'wicked-web/layouts/Base.astro';
import Topbar from 'wicked-web/components/Topbar.astro';
import Footer from 'wicked-web/components/Footer.astro';
import '../styles/interactive.css';

const title = 'wicked-interactive — Point at the page. Say the change. Ship it tonight.';
const description = 'Describe a deck, doc, landing page, or demo video in plain language and watch it build in your browser. Then click any block and say the change — only that block reworks, everything else holds. Export self-contained HTML, PDF, PowerPoint, or video. No code, no design tickets — it runs on the Claude Code session already in your terminal.';
const repo = 'https://github.com/mikeparcewski/wicked-interactive';
---

<Base title={title} description={description}>
  <Topbar pkg="wicked-interactive" repo={repo} />

  <!-- ════ ROOM 1 — HERO (from the LIVE build) ═══════════════════════════ -->
  <section class="hero" id="top">
    <div class="wrap">
      <div class="kicker">Interactive builder · point-and-say editing</div>
      <h1>Point at the page. Say the change. <span class="y">Ship it tonight.</span></h1>
      <p class="lede">Describe a doc and watch it build, live. Then click any block and say what to change &mdash; <b>only that block reworks</b>, everything else holds perfectly still.</p>
      <a class="down" href="#point">It's live just below</a>
    </div>
  </section>

  <!-- ════ ROOM 2 — POINT AT ANYTHING (the live editor) ══════════════════ -->
  <section class="band point" id="point">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-eyebrow"><b>01</b> Point at anything</span>
        <h2 class="sec-title">Describe it. Point at a block. <span class="y">Say the change.</span></h2>
        <p class="sec-intro">A real, driven editor &mdash; not a screenshot. Describe a document, watch it build block by block, then click any block and say the change. <b>Only that block reworks;</b> steal a brand's look from a URL and send it to the judges before you ship.</p>
      </div>

      <div class="editor" id="editor">
        <div class="ed-formats" role="group" aria-label="Point at any format">
          <span class="ed-formats__lbl">Point at anything</span>
          <button class="ed-fmt is-active" type="button" data-fmt="brief">Launch brief</button>
          <button class="ed-fmt" type="button" data-fmt="deck">Investor deck</button>
          <button class="ed-fmt" type="button" data-fmt="page">Landing page</button>
        </div>

        <div class="ed-frame" id="edFrame">
          <div class="ed-chrome">
            <span class="ed-lights" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="ed-url" id="edUrl">localhost:4400 · q3-launch-brief.html</span>
            <span class="ed-live"><span class="ed-pulse" aria-hidden="true"></span>Live</span>
          </div>

          <form class="ed-prompt" id="edPromptForm">
            <span class="ed-you">You</span>
            <input class="ed-input" id="edInput" type="text" autocomplete="off"
                   aria-label="Describe the document to build"
                   value="One-page Q3 launch brief for the whole team." />
            <button class="ed-build" type="submit">Build &crarr;</button>
          </form>

          <div class="ed-doc" id="edDoc" aria-live="polite"></div>

          <div class="ed-cue" id="edCue" data-state="idle">
            <span class="ed-cue__dot" aria-hidden="true"></span>
            <span class="ed-cue__txt" id="edCueTxt">Building your first draft&hellip;</span>
          </div>

          <div class="ed-export" id="edExport">
            <span class="ed-export__lbl">Ship it</span>
            <button class="ed-ex" type="button" data-ex="HTML">HTML</button>
            <button class="ed-ex" type="button" data-ex="PDF">PDF</button>
            <button class="ed-ex" type="button" data-ex="PPTX">PowerPoint</button>
            <button class="ed-ex" type="button" data-ex="Video">Video</button>
            <span class="ed-export__status" id="edExStatus"></span>
          </div>
        </div>

        <div class="ed-tools">
          <div class="ed-tool ed-tool--style">
            <span class="ed-tool__lbl">Steal any brand's look</span>
            <form class="ed-style" id="edStyleForm">
              <input class="ed-style__url" id="edStyleUrl" type="text" autocomplete="off"
                     placeholder="paste a URL whose design you like&hellip;" aria-label="Import a style from a URL" />
              <button class="ed-style__go" type="submit">Import style</button>
            </form>
            <div class="ed-brands" role="group" aria-label="Or pick a brand">
              <span class="ed-brands__or">or try</span>
              <button class="ed-brand" type="button" data-theme="stripe">stripe.com</button>
              <button class="ed-brand" type="button" data-theme="linear">linear.app</button>
              <button class="ed-brand" type="button" data-theme="sunset">sunset.studio</button>
            </div>
          </div>
          <div class="ed-tool ed-tool--review">
            <span class="ed-tool__lbl">Send it to the judges</span>
            <div class="ed-judges" role="group" aria-label="Run a review pass">
              <button class="ed-judge" type="button" data-rev="match"><span class="ed-judge__s" aria-hidden="true"></span>Brand&nbsp;match</button>
              <button class="ed-judge" type="button" data-rev="a11y"><span class="ed-judge__s" aria-hidden="true"></span>Accessibility</button>
              <button class="ed-judge" type="button" data-rev="copy"><span class="ed-judge__s" aria-hidden="true"></span>Copy</button>
              <button class="ed-judge" type="button" data-rev="qe"><span class="ed-judge__s" aria-hidden="true"></span>QE</button>
            </div>
            <div class="ed-verdicts" id="edVerdicts" aria-live="polite"></div>
          </div>
        </div>

        <div class="ed-rail" aria-label="Version history">
          <div class="ed-rail__head">Versions<span>click to rewind</span></div>
          <div class="ed-pips" id="edPips"></div>
        </div>

        <p class="ed-note"><b>Real point-and-say editing, style import, and reviewers.</b> This on-page demo is canned for the tour; the product itself runs on the Claude Code session already in your terminal &mdash; no extra setup, nothing leaves your machine.</p>
      </div>
    </div>
  </section>

  <!-- ════ ROOM 3 — DEMO VIDEO (revived from the LIVE build) ═════════════ -->
  <section class="band demo" id="demo">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-eyebrow"><b>02</b> Demo video</span>
        <h2 class="sec-title">Point it at your app. <span class="y">Get a narrated walkthrough.</span></h2>
        <p class="sec-intro">Give it a URL and a brief. wicked-interactive explores your app, scripts a Playwright spec, records it with narration captions, and hands back an interactive storyboard. <b>No screen-recording tools. No editing.</b></p>
      </div>

      <div class="demo-grid">
        <div class="vid-step-ledger" role="group" aria-label="Jump to a step">
          <button class="vid-step is-active" type="button" data-ledger="1">
            <div class="vs-num">01</div><div class="vs-lab">Aim</div><div class="vs-hint">Your app URL + brief.</div>
          </button>
          <button class="vid-step" type="button" data-ledger="2">
            <div class="vs-num">02</div><div class="vs-lab">Explore</div><div class="vs-hint">Agent maps the app.</div>
          </button>
          <button class="vid-step" type="button" data-ledger="3">
            <div class="vs-num">03</div><div class="vs-lab">Record</div><div class="vs-hint">Playwright captures it.</div>
          </button>
          <button class="vid-step" type="button" data-ledger="4">
            <div class="vs-num">04</div><div class="vs-lab">Storyboard</div><div class="vs-hint">Interactive output.</div>
          </button>
        </div>

        <div class="vid-player" id="vidPlayer">
          <div class="vid-chrome">
            <span class="vid-tl"></span><span class="vid-tl"></span><span class="vid-tl"></span>
            <span class="vid-urlbar" id="vUrl">localhost:4400 · new demo</span>
            <span class="vid-rec"><span class="vid-rec-dot" id="vDot"></span><span id="vRecTime"></span></span>
          </div>
          <div class="vid-screen">
            <div class="vid-state is-on" id="vS1">
              <div class="vid-slabel">Step 1 — aim</div>
              <div class="vid-form">
                <div class="vid-field">
                  <span class="vid-flabel">Your app URL</span>
                  <div class="vid-finput">http://localhost:3000<span class="vc"></span></div>
                </div>
                <div class="vid-field">
                  <span class="vid-flabel">What to demo</span>
                  <div class="vid-ftext">Walk through creating a new project, then export as PDF.</div>
                </div>
                <button class="vid-gobtn" type="button" tabindex="-1">Record demo →</button>
              </div>
            </div>
            <div class="vid-state" id="vS2">
              <div class="vid-slabel">Agent · mapping localhost:3000</div>
              <div class="vid-term">
                <div class="vid-log">
                  <div class="vid-log-line"><span class="vid-log-arr">→</span>Visiting http://localhost:3000</div>
                  <div class="vid-log-line"><span class="vid-log-arr">→</span>Crawling routes &amp; interactions…</div>
                  <div class="vid-log-line"><span class="vid-log-arr">→</span>Found: /dashboard, /projects/new, /export</div>
                  <div class="vid-log-line vid-log-hi"><span class="vid-log-arr">→</span>Authoring demo.spec.mjs · 4 chapters planned</div>
                  <div class="vid-log-line vid-log-dim"><span class="vid-log-arr">→</span>Ready to record<span class="vc-sm"></span></div>
                </div>
              </div>
              <div class="vid-routebar">
                <span class="vid-routetag">/dashboard</span>
                <span class="vid-routetag">/projects/new</span>
                <span class="vid-routetag">/export</span>
              </div>
            </div>
            <div class="vid-state" id="vS3">
              <div class="vid-slabel">Playwright · recording localhost:3000</div>
              <div class="vid-target">
                <div class="vid-target-bar">
                  <span class="vid-tl" style="background:#ff5f57;width:8px;height:8px"></span>
                  <span class="vid-tl" style="background:#febc2e;width:8px;height:8px"></span>
                  <span class="vid-tl" style="background:#28c840;width:8px;height:8px"></span>
                  <span class="vid-target-url">localhost:3000 · projects / new</span>
                </div>
                <div class="vid-target-content">
                  <div class="vid-target-h">New project</div>
                  <div class="vid-target-r" style="width:42%"></div>
                  <div class="vid-target-r sel"></div>
                  <div class="vid-target-r" style="width:70%"></div>
                  <div class="vid-target-r" style="width:88%"></div>
                  <div class="vid-target-r" style="width:55%"></div>
                  <div class="vid-target-rbtn"></div>
                </div>
                <div class="vid-cursor" aria-hidden="true"></div>
                <div class="vid-caption">Filling in the project name field…</div>
              </div>
            </div>
            <div class="vid-state" id="vS4">
              <div class="vid-slabel">Output · storyboard.html</div>
              <div class="vid-storyboard">
                <div class="vid-sb-preview">
                  <div class="vid-preview-ui" aria-hidden="true">
                    <div class="vpu-chrome">
                      <span class="vpu-win"></span><span class="vpu-win"></span><span class="vpu-win"></span>
                      <div class="vpu-url"></div>
                    </div>
                    <div class="vpu-appnav">
                      <div class="vpu-logo"></div>
                      <div class="vpu-navlinks"><div></div><div class="hi"></div><div></div><div></div></div>
                      <div class="vpu-btn"></div>
                    </div>
                    <div class="vpu-layout">
                      <div class="vpu-sidebar">
                        <div class="vpu-si hi"></div>
                        <div class="vpu-si"></div>
                        <div class="vpu-si"></div>
                        <div class="vpu-si"></div>
                        <div class="vpu-si"></div>
                      </div>
                      <div class="vpu-main">
                        <div class="vpu-heading"></div>
                        <div class="vpu-sub"></div>
                        <div class="vpu-cards"><div></div><div></div><div></div></div>
                      </div>
                    </div>
                  </div>
                  <div class="vpu-cursor"></div>
                  <div class="vid-sb-play">▶</div>
                  <div class="vid-sb-duration">1:34</div>
                </div>
                <div class="vid-sb-chapters">
                  <div class="vid-sb-ch active">
                    <div class="vid-sb-thumb">
                      <div class="vsbt-nav"></div>
                      <div class="vsbt-page">
                        <div class="vsbt-side"><div class="hi"></div><div></div><div></div><div></div></div>
                        <div class="vsbt-main">
                          <div class="vsbt-head"></div><div class="vsbt-row w80"></div>
                          <div class="vsbt-cards"><div></div><div></div><div></div></div>
                        </div>
                      </div>
                    </div>
                    <span>01 · Dashboard</span>
                  </div>
                  <div class="vid-sb-ch">
                    <div class="vid-sb-thumb">
                      <div class="vsbt-nav"></div>
                      <div class="vsbt-page">
                        <div class="vsbt-side"><div></div><div class="hi"></div><div></div><div></div></div>
                        <div class="vsbt-main">
                          <div class="vsbt-head"></div><div class="vsbt-row w80"></div>
                          <div class="vsbt-cards"><div></div><div></div></div>
                        </div>
                      </div>
                    </div>
                    <span>02 · New project</span>
                  </div>
                  <div class="vid-sb-ch">
                    <div class="vid-sb-thumb">
                      <div class="vsbt-nav"></div>
                      <div class="vsbt-page">
                        <div class="vsbt-side"><div></div><div class="hi"></div><div></div><div></div></div>
                        <div class="vsbt-main">
                          <div class="vsbt-head"></div><div class="vsbt-row hi"></div>
                          <div class="vsbt-cards"><div></div><div></div></div>
                        </div>
                      </div>
                    </div>
                    <span>03 · Fill in</span>
                  </div>
                  <div class="vid-sb-ch">
                    <div class="vid-sb-thumb">
                      <div class="vsbt-nav"></div>
                      <div class="vsbt-page">
                        <div class="vsbt-main">
                          <div class="vsbt-head"></div><div class="vsbt-row w55"></div><div class="vsbt-row w40"></div>
                          <div class="vsbt-cards"><div></div><div></div><div></div></div>
                        </div>
                      </div>
                    </div>
                    <span>04 · Export PDF</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="vid-controls">
            <div class="vid-timeline">
              <div class="vid-bar"><div class="vid-fill" id="vFill"></div></div>
              <div class="vid-chs">
                <button class="vid-ch now" type="button" id="vC1">Aim</button>
                <button class="vid-ch" type="button" id="vC2">Explore</button>
                <button class="vid-ch" type="button" id="vC3">Record</button>
                <button class="vid-ch" type="button" id="vC4">Storyboard</button>
              </div>
            </div>
            <button class="vid-dl" type="button" id="vDl">View →</button>
          </div>
        </div>
      </div>

      <p class="vid-demo-note"><b>The four steps auto-play &mdash; or click any step to jump.</b> This on-page walkthrough is canned; the real recorder drives a live Playwright session against your own running app and hands back a self-contained storyboard.</p>
    </div>
  </section>

  <!-- ════ ROOM 4 — MAKE ANYTHING / SEND ANYTHING (NEW build) ════════════ -->
  <section class="band io">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-eyebrow"><b>03</b> One canvas, every format</span>
        <h2 class="sec-title">Make anything. <span class="y">Send anything.</span></h2>
        <p class="sec-intro">The stuff you'd normally dread &mdash; built as real, interactive HTML, then handed off as one file anyone can open. Pick a format on the left; it loads in the editor above.</p>
      </div>

      <div class="io-grid">
        <div class="io-col io-col--in">
          <span class="io-col__lbl">What you make</span>
          <ul class="io-cards">
            <li>
              <button class="io-card" type="button" data-load="deck">
                <span class="io-card__t">
                  <svg class="io-card__glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="12" rx="2"/><line x1="8" y1="20" x2="16" y2="20"/><line x1="12" y1="16" x2="12" y2="20"/></svg>
                  Decks <span class="io-card__go">Load ↑</span>
                </span>
                <span class="io-card__d">Board updates, pitch decks, QBRs &mdash; on-brand and export-ready, not a sad bulleted list.</span>
              </button>
            </li>
            <li>
              <button class="io-card" type="button" data-load="brief">
                <span class="io-card__t">
                  <svg class="io-card__glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2h9l5 5v15H6z"/><path d="M14 2v6h6"/><line x1="9" y1="13" x2="16" y2="13"/><line x1="9" y1="17" x2="16" y2="17"/></svg>
                  Docs &amp; one-pagers <span class="io-card__go">Load ↑</span>
                </span>
                <span class="io-card__d">Reports, briefs, proposals, the FAQ nobody wants to write &mdash; one page everyone can act on.</span>
              </button>
            </li>
            <li>
              <button class="io-card" type="button" data-load="page">
                <span class="io-card__t">
                  <svg class="io-card__glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="7" y1="14" x2="14" y2="14"/></svg>
                  Landing &amp; marketing pages <span class="io-card__go">Load ↑</span>
                </span>
                <span class="io-card__d">Launch pages, pricing, sales pages &mdash; anything that lives on the web, built as real HTML.</span>
              </button>
            </li>
            <li>
              <button class="io-card" type="button" data-goto="demo">
                <span class="io-card__t">
                  <svg class="io-card__glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><polygon points="10,9 16,12 10,15" fill="currentColor" stroke="none"/></svg>
                  Demo videos <span class="io-card__go">See it ↑</span>
                </span>
                <span class="io-card__d">Point it at your live app, say what to show &mdash; it records a narrated walkthrough with chapter thumbnails.</span>
              </button>
            </li>
          </ul>
        </div>

        <div class="io-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"/><polyline points="14,6 20,12 14,18"/></svg>
          <span>one file</span>
        </div>

        <div class="io-col io-col--out">
          <span class="io-col__lbl">How you send it</span>
          <ul class="io-cards">
            <li>
              <div class="io-card">
                <span class="io-card__t">HTML <span class="io-out__tag">self-contained</span></span>
                <span class="io-card__d">One file with everything inlined &mdash; opens straight from disk, stays interactive, nothing to host.</span>
              </div>
            </li>
            <li>
              <div class="io-card">
                <span class="io-card__t">PDF <span class="io-out__tag">print-ready</span></span>
                <span class="io-card__d">The same document rendered to a clean, shareable PDF for the people who still want one.</span>
              </div>
            </li>
            <li>
              <div class="io-card">
                <span class="io-card__t">PowerPoint <span class="io-out__tag">native .pptx</span></span>
                <span class="io-card__d">A real, editable PowerPoint &mdash; hand it to someone who lives in slides and they can keep going.</span>
              </div>
            </li>
            <li>
              <div class="io-card">
                <span class="io-card__t">Video <span class="io-out__tag">narrated</span></span>
                <span class="io-card__d">The recorded walkthrough as an MP4 with a chaptered storyboard &mdash; share the link, done.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ ROOM 5 — UNDER THE HOOD (NEW build) ═══════════════════════════ -->
  <section class="band hood">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-eyebrow"><b>04</b> Under the hood</span>
        <h2 class="sec-title">More than a pretty draft. <span class="y">A real editing engine.</span></h2>
        <p class="sec-intro">The demos above are the tip of it. Here's what the agent in your terminal actually does &mdash; every piece of it real, not a mockup.</p>
      </div>

      <ul class="hood-grid">
        <li class="hood-card">
          <span class="hood-card__k">Anchored edits</span>
          <h3>The invariant that freezes everything else</h3>
          <p>Every block is stamped with a <code>data-wid</code>. When you change one, an invariant checks that <em>every other anchor survives byte-for-byte</em> &mdash; drift isn't discouraged, it's impossible.</p>
        </li>
        <li class="hood-card">
          <span class="hood-card__k">Deterministic&nbsp;first</span>
          <h3>Instant where it can be, smart where it must be</h3>
          <p>Change text, swap a style, remove a block &mdash; those land <em>the instant you submit</em>, no model in the loop. Only a real rewrite or a whole-doc rethink calls the AI. Fast by default.</p>
        </li>
        <li class="hood-card hood-card--feature">
          <span class="hood-card__k">Style import</span>
          <h3>Steal any brand's look from a URL</h3>
          <p>Point it at a page whose design you like. It renders that page, <em>reads the design</em>, synthesizes a theme, and re-skins your whole document &mdash; and the look sticks for every later edit. (Try it in the editor above.)</p>
        </li>
        <li class="hood-card hood-card--feature">
          <span class="hood-card__k">The judges</span>
          <h3>Four reviewers grade it before you send it</h3>
          <p>Brand&nbsp;match, accessibility, copy, and QE each run as an independent pass and post a verdict &mdash; non-blocking, so you keep working. Catch the contrast fail or the passive sentence before your audience does.</p>
        </li>
        <li class="hood-card">
          <span class="hood-card__k">Your real numbers</span>
          <h3>It reads your files, so the figures are real</h3>
          <p>Drop in files and folders; it indexes them live and grounds every stat in what's actually there. <em>No invented numbers</em> to fill a slot &mdash; the ones that don't check out get flagged.</p>
        </li>
        <li class="hood-card">
