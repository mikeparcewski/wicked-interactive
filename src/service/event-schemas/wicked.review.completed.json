{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review pass completed",
  "type": "object",
  "required": [
    "document_id",
    "ts"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "reviewer": {
      "type": "string",
      "enum": ["match", "a11y", "copy", "qe"]
    },
    "verdict": {
      "type": "string"
    },
    "passed": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
