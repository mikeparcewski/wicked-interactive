{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review pass requested",
  "type": "object",
  "required": [
    "document_id",
    "ts"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["match", "a11y", "copy", "qe"]
      }
    }
  },
  "additionalProperties": true
}
