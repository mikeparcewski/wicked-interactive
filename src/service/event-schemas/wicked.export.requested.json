{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Export produced",
  "type": "object",
  "required": [
    "document_id",
    "ts",
    "version",
    "format"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "format": {
      "enum": [
        "html",
        "pdf",
        "pptx"
      ]
    }
  },
  "additionalProperties": true
}
