{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Document created",
  "type": "object",
  "required": [
    "document_id",
    "ts",
    "kind"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "blank",
        "html",
        "source",
        "demo"
      ]
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "brief": {
      "type": "string"
    },
    "url": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
