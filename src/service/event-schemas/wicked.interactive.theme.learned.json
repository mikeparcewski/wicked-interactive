{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Theme source grabbed (URL rendered to PDF)",
  "type": "object",
  "required": [
    "document_id",
    "ts"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "render_path": {
      "type": "string"
    },
    "format": {
      "enum": [
        "pdf"
      ]
    }
  },
  "additionalProperties": true
}
