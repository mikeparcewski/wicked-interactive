{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Status heartbeat — UI nudges the agent for a fresh progress update",
  "type": "object",
  "required": [
    "document_id",
    "ts"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "since_ms": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
