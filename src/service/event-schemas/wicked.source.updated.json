{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source index status updated",
  "type": "object",
  "required": [
    "document_id",
    "ts",
    "path",
    "status"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "indexing",
        "indexed",
        "error"
      ]
    },
    "brain": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
